{
  "hooks": {
    "SessionStart": [
      {
        "name": "engram-session-start",
        "type": "command",
        "command": "node ${extensionPath}/scripts/session-start.js",
        "description": "Initializes Engram session context"
      }
    ],
    "SessionEnd": [
      {
        "name": "engram-session-end",
        "type": "command",
        "command": "node ${extensionPath}/scripts/session-end.js",
        "description": "Finalizes Engram session"
      }
    ]
  }
}